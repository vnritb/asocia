DATABASE_URL=postgres://asocia:asocia@localhost:5432/asocia
PORT=4002
# Este servicio NO valida tokens de sesión: confía en que quien le habla es
# el api-gateway, que ya ha resuelto el Bearer token contra membership-service
# y reenvía la identidad en estas cabeceras internas.
TRUSTED_GATEWAY_HEADER_USER_ID=x-user-id
TRUSTED_GATEWAY_HEADER_USER_NAME=x-user-name
