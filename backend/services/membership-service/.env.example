DATABASE_URL=postgres://asocia:asocia@localhost:5432/asocia
PORT=4001
# Clave compartida sencilla para las rutas /v1/admin/* (usadas por el
# futuro backoffice). Sustituir por JWT con rol admin en producción.
ADMIN_API_KEY=changeme-admin-key
# Para mantener sincronizado el directorio de "chateables" en chat-service
# (ver syncChatDirectory en src/index.ts). Debe coincidir con
# INTERNAL_API_KEY de chat-service.
CHAT_SERVICE_URL=http://localhost:4002
INTERNAL_API_KEY=changeme-internal-key
